{
    "actorSpecification": 1,
    "name": "linkedin-job-scraper",
    "title": "LinkedIn Job Scraper — No Cookies ✅ Salary, Skills & Company",
    "description": "Scrape linkedin.com job postings without login or cookies. Salary, skills, and employer data in clean structured output — from $0.27 per 1,000 jobs. Incremental mode skips already-seen jobs on recurring runs for hiring research and lead generation.",
    "version": "0.1",
    "buildTag": "latest",
    "readme": "../README.md",
    "environmentVariables": {
        "OPS_INGEST_URL": "https://ops.blackfalcondata.com/ingest",
        "OPS_SECRET": "@OPS_SECRET"
    },
    "dockerfile": "../Dockerfile",
    "input": "./input_schema.json",
    "output": "./output_schema.json",
    "storages": {
        "dataset": "./dataset_schema.json"
    },
    "defaultRunOptions": {
        "memoryMbytes": 256,
        "timeoutSecs": 3600
    },
    "minMemoryMbytes": 256,
    "maxMemoryMbytes": 1024,
    "exampleRunInput": {
        "body": {
            "keywords": "software engineer",
            "location": "United States",
            "datePosted": "last24h",
            "maxResults": 100
        },
        "contentType": "application/json"
    },
    "examples": [
        {
            "name": "Recent US software-engineer jobs",
            "taskSlug": "linkedin-job-by-role",
            "taskTitle": "LinkedIn Job Scraper by Role",
            "taskDescription": "Scrape LinkedIn jobs by role or keyword — location, description and date. Structured JSON, ready to run.",
            "input": {
                "keywords": "software engineer",
                "geoIds": [
                    "103644278"
                ],
                "datePosted": "last24h",
                "maxResults": 100
            }
        },
        {
            "name": "Nordic preset, all engineering roles",
            "taskSlug": "linkedin-job-by-city",
            "taskTitle": "LinkedIn Job Scraper by City",
            "taskDescription": "Scrape LinkedIn jobs for any city or region — location, description and date. Structured, ready to run.",
            "input": {
                "keywords": "engineer",
                "regionPresets": "nordic",
                "datePosted": "last7d",
                "maxResults": 200
            }
        },
        {
            "name": "Daily delta feed (incremental)",
            "taskSlug": "linkedin-job-remote-jobs",
            "taskTitle": "LinkedIn Remote Job Scraper",
            "taskDescription": "Scrape remote LinkedIn jobs — location, description and date. Filter to work-from-home roles, structured JSON.",
            "input": {
                "keywords": "software engineer",
                "geoIds": [
                    "103644278"
                ],
                "datePosted": "last24h",
                "maxResults": 500,
                "incrementalMode": true,
                "stateKey": "us-software-engineer-daily"
            }
        },
        {
            "name": "Remote roles globally with detail enrichment",
            "taskSlug": "linkedin-job-new-jobs-monitor",
            "taskTitle": "LinkedIn New Jobs Monitor",
            "taskDescription": "Monitor new LinkedIn jobs — incremental runs return only fresh postings. location, description and date.",
            "input": {
                "keywords": "senior backend engineer",
                "workType": [
                    "remote"
                ],
                "datePosted": "last7d",
                "enrichDetails": true,
                "maxResults": 50,
                "incrementalMode": true
            }
        },
        {
            "name": "Recent US software-engineer jobs",
            "input": {
                "keywords": "software engineer",
                "geoIds": [
                    "103644278"
                ],
                "datePosted": "last24h",
                "maxResults": 100
            }
        },
        {
            "name": "Nordic preset, all engineering roles",
            "input": {
                "keywords": "engineer",
                "regionPresets": "nordic",
                "datePosted": "last7d",
                "maxResults": 200
            }
        },
        {
            "name": "Daily delta feed (incremental)",
            "input": {
                "keywords": "software engineer",
                "geoIds": [
                    "103644278"
                ],
                "datePosted": "last24h",
                "maxResults": 500,
                "incrementalMode": true,
                "stateKey": "us-software-engineer-daily"
            }
        },
        {
            "name": "Remote roles globally with detail enrichment",
            "input": {
                "keywords": "senior backend engineer",
                "workType": [
                    "remote"
                ],
                "datePosted": "last7d",
                "enrichDetails": true,
                "maxResults": 50
            }
        }
    ],
    "categories": [
        "JOBS",
        "LEAD_GENERATION",
        "AUTOMATION"
    ],
    "pricingInfos": [
        {
            "pricingModel": "PAY_PER_EVENT",
            "pricingPerEvent": {
                "actorChargeEvents": {
                    "apify-actor-start": {
                        "eventTitle": "Actor Start",
                        "eventDescription": "Charged when the Actor starts running.",
                        "isOneTimeEvent": true,
                        "eventPriceUsd": 0.0005
                    },
                    "apify-default-dataset-item": {
                        "eventTitle": "Result",
                        "eventDescription": "Single result in the default dataset. $0.27 per 1,000 jobs — pay only for fresh deltas in incremental mode.",
                        "isOneTimeEvent": false,
                        "eventPriceUsd": 0.00027,
                        "isPrimaryEvent": true
                    }
                }
            },
            "apifyMarginPercentage": 0.2
        }
    ]
}
